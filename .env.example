# ============================================================
# NetworkSecurity - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to Git (it is already in .gitignore).
# ============================================================

# ------------------------------------------------------------------
# MongoDB Atlas connection string (required)
# Get this from MongoDB Atlas > Clusters > Connect > Drivers
# Free M0 cluster: https://www.mongodb.com/atlas/database
# ------------------------------------------------------------------
MONGODB_URL_KEY=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ------------------------------------------------------------------
# DagShub / MLflow tracking (optional – needed only for training)
# Get credentials from: https://dagshub.com
# ------------------------------------------------------------------
DAGSHUB_USER_TOKEN=<your_dagshub_token>
MLFLOW_TRACKING_URI=https://dagshub.com/<username>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=<your_dagshub_username>
MLFLOW_TRACKING_PASSWORD=<your_dagshub_token>

# ------------------------------------------------------------------
# AWS S3 (optional – needed only if you sync models to S3)
# Free tier is available through the GitHub Student Developer Pack:
# https://education.github.com/pack
# ------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<your_aws_access_key>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_key>
AWS_REGION=us-east-1
AWS_BUCKET_NAME=<your_s3_bucket_name>
